{
  "info": {
    "name": "Political Transparency API",
    "description": "Collection of API endpoints for testing the Political Transparency application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Districts",
      "item": [
        {
          "name": "Get All Districts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/v1/districts",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "districts"]
            },
            "description": "Retrieves all congressional districts with their GeoJSON boundaries"
          }
        },
        {
          "name": "Get District by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/v1/districts/CA-12",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "districts", "CA-12"]
            },
            "description": "Get a specific district by ID (e.g., CA-12)"
          }
        },
        {
          "name": "Get District Candidates",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/v1/districts/CA-12/candidates",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "districts", "CA-12", "candidates"]
            },
            "description": "Get all candidates for a specific district"
          }
        },
        {
          "name": "Get NY-14 District",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/v1/districts/NY-14",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "districts", "NY-14"]
            },
            "description": "Get New York 14th district"
          }
        },
        {
          "name": "Get TX-21 Candidates",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/v1/districts/TX-21/candidates",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "districts", "TX-21", "candidates"]
            },
            "description": "Get candidates for Texas 21st district"
          }
        }
      ]
    },
    {
      "name": "Candidates",
      "item": [
        {
          "name": "Get Candidate by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/v1/candidates/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "candidates", "1"]
            },
            "description": "Get full candidate profile including bio, voting record, and funding"
          }
        },
        {
          "name": "Get Candidate 2",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/v1/candidates/2",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "candidates", "2"]
            },
            "description": "Get another candidate's profile"
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Root Endpoint",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": [""]
            },
            "description": "Check if API is running"
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["health"]
            },
            "description": "Health check endpoint for monitoring"
          }
        },
        {
          "name": "API Documentation",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/docs",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["docs"]
            },
            "description": "Interactive API documentation (Swagger UI)"
          }
        }
      ]
    }
  ]
}
